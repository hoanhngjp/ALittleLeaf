# Cấu hình CSDL
DB_CONNECTION_STRING=Server=sqlserver;Database=your_db;User Id=your_user;Password=your_password;
MSSQL_SA_PASSWORD=YourStrongPassword

# Cấu hình VNPAY
VNPAY_TMNCODE=your_TmnCode
VNPAY_HASHSECRET=your_HashSecret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# Cấu hình URL trả về
# ReturnUrl → React frontend page (public route, no auth required)
#   Local dev : http://localhost:5173/payment-result
#   Docker    : http://localhost:3000/payment-result
Vnpay__PaymentBackReturnUrl=http://localhost:5173/payment-result
# IPN → backend API endpoint (must be internet-accessible; use ngrok for local dev)
VNPAY_IPN_URL=https://your-ngrok-id.ngrok-free.app/api/payment/vnpay-ipn

# Cấu hình JWT_Secret
JWT_SECRET=Your_Strong_JWT_Secret_Key_123Aa@

# Cấu hình CLOUDINARY
CLOUDINARY_CLOUD_NAME=Your_Cloudinary_Name
CLOUDINARY_API_KEY=Your_Cloudinary_API_Key
CLOUDINARY_API_SECRET=Your_Cloudinary_API_Secret
CLOUDINARY_SECURE=true

# Cấu hình GHN (Giao Hàng Nhanh)
# Sandbox: https://dev-online-gateway.ghn.vn/shiip/public-api
# Production: https://online-gateway.ghn.vn/shiip/public-api
GHN_API_KEY=your_ghn_api_key
GHN_SHOP_ID=your_shop_id
GHN_BASE_URL=https://dev-online-gateway.ghn.vn/shiip/public-api

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_oauth_client_id